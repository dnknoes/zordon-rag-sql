# Copy to .env and adjust. All values have safe local defaults; no secrets required.
# The bundled demo + eval run fully offline (mock LLM + in-memory vector store),
# so none of these are needed unless you wire in real Ollama + Chroma.

# --- Local LLM (Ollama) ---
# Used by the optional live demo: `npm run demo:ollama`. Local-only; no tokens/keys.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Vector store (Chroma) ---
CHROMA_URL=http://localhost:8000
ZORDON_CHROMA_URL=http://localhost:8000
ZORDON_CHROMA_COLLECTION=zordon_demo

# --- Engine behavior ---
ZORDON_DIALECT=mysql
ZORDON_MIN_DOCS=3
